  "tools": [
    {
      "id": "xcode-clt",
      "name": "Xcode Command Line Tools",
      "description": "Apple's developer tools (compilers, git, make)",
      "category": "essentials",
      "icon": "hammer",
      "icon_color": "blue",
      "depends_on": [],
      "check": {
        "command": "xcode-select -p 2>/dev/null",
        "version_command": "xcode-select --version 2>&1 | head -1"
      },
      "install": {
        "method": "script",
        "script": "xcode-select --install"
      }
    },
    {
      "id": "homebrew",
      "name": "Homebrew",
      "description": "The missing package manager for macOS",
      "category": "essentials",
      "icon": "mug",
      "icon_color": "orange",
      "depends_on": ["xcode-clt"],
      "check": {
        "command": "command -v brew",
        "version_command": "brew --version 2>&1 | head -1"
      },
      "install": {
        "method": "script",
        "url": "https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh",
        "requires_admin": true
      }
    },

    {
      "id": "git",
